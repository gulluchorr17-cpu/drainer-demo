{
  "name": "drainer-demo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "anchor build",
    "deploy": "anchor deploy --provider.cluster devnet",
    "init-config": "ts-node scripts/initialize.ts",
    "flip-on": "ts-node scripts/flip.ts on",
    "flip-off": "ts-node scripts/flip.ts off",
    "serve": "npx http-server frontend -p 3000 -c-1 --cors",
    "build:static": "node scripts/build-static.js",
    "start": "ts-node scripts/flip-server.ts",
    "flip-server": "ts-node scripts/flip-server.ts",
    "demo": "echo Starting demo servers... && start /b npx ts-node scripts/flip-server.ts && npx http-server frontend -p 3000 -c-1 --cors"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.31.1",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.95.0",
    "bs58": "^5.0.0"
  },
  "devDependencies": {
    "@types/chai": "^4.3.0",
    "@types/mocha": "^10.0.0",
    "@types/node": "^25.5.0",
    "chai": "^4.3.7",
    "http-server": "^14.1.1",
    "mocha": "^10.2.0",
    "ts-mocha": "^10.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
